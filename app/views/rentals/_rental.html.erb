<%# locals: (rental: nil, living_unit: nil) -%>

<div
  class="basis-full bg-base-300 rounded-lg min-h-24 p-2 flex flex-row"
  id="<%= dom_id(rental) %>"
>
  <div class="flex flex-1">
    <div class="basis-1/2">
      <p class="font-semibold">
        <%= t("rental.label.description") %>
      </p>
      <div class="mt-2">
        <%= rental.description %>
      </div>
    </div>
    <div class="basis-1/2 flex justify-end items-center">
      <% unless rental.archived? %>
        <%= link_to living_unit_rental_path(living_unit, rental),
                class: "btn btn-circle btn-outline mr-2 tooltip inline-flex",
                data: {
                  turbo_method: :delete,
                  tip: t("rental.tooltip.archive")
                } do %>
          <%= icon(:archive, css: "size-6") %>
        <% end %>
        <%= link_to edit_living_unit_rental_path(living_unit, rental),
                class: "btn btn-circle btn-outline mr-2 tooltip inline-flex",
                data: {
                  turbo_frame: "main_content",
                  tip: t("rental.tooltip.edit")
                } do %>
          <%= icon(:pencil, css: "size-6") %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
