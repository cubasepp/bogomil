<%# locals: (f: nil, disabled: false) -%>

<div class="flex mt-2">
  <div class="basis-1/2">
    <p class="font-semibold pl-2">
      <%= t("rental.section_2") %>
    </p>
  </div>
  <div class="basis-1/2 flex justify-end">
    <span
      class="flex btn btn-circle btn-outline tooltip"
      data-tip="<%= t("rental.tooltip.tenant.add") %>"
      data-action="click->rental#addTenant"
    >
      <%= icon(:plus, css: "size-6") %>
    </span>
  </div>
</div>
<div data-rental-target="tenants">
  <%= f.simple_fields_for :tenants do |tenant_f| %>
    <div class="flex flex-col" id="tenants_<%= tenant_f.index %>">
      <div class="flex gap-2">
        <div class="flex-1 bg-base-300 p-4 rouned">
          <%= tenant_f.input :first_name, disabled: %>
          <%= tenant_f.input :last_name, disabled: %>
        </div>
        <div class="flex-1 bg-base-300 p-4 rounded">
          <%= tenant_f.input :email, disabled: %>
          <%= tenant_f.input :phone_number, disabled: %>
        </div>
      </div>
      <div class="basis-full flex justify-end mr-4">
        Div 3
      </div>
    </div>
  <% end %>
</div>
